# Copy to .env and fill in. Do NOT commit .env.

# Public URL Claude will reach this server at. Must match the Caddy
# reverse-proxy host and must be HTTPS.
MCP_PUBLIC_URL=https://loseit-mcp.felixrouleau.com

# Single static password used to approve OAuth authorisation. Generate:
#   openssl rand -base64 96 | tr -d '\n'
MCP_ADMIN_PASSWORD=

# First-boot LoseIt token seeds. After the first successful refresh the
# server persists the current tokens to /data/loseit_tokens.json and
# these become unused — you can blank them for subsequent deploys.
MCP_LOSEIT_REFRESH_TOKEN=
MCP_LOSEIT_ACCESS_TOKEN=
MCP_LOSEIT_USER_ID=
MCP_LOSEIT_USERNAME=

TZ=America/Toronto
